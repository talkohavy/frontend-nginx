{
  "name": "frontend-nginx",
  "version": "1.0.0",
  "description": "Production-grade NGINX server for serving static frontend files",
  "private": true,
  "scripts": {
    "build": "docker build . -f Dockerfile -t frontend-nginx:123 -t frontend-nginx:latest",
    "dev": "docker run -it --rm --name frontend-nginx -p 80:80 -p 443:443 -v \"$(pwd)/certs:/etc/nginx/ssl:ro\" frontend-nginx",
    "create-certificates": "sh scripts/create-certificates.sh",
    "server-cert": "sh scripts/create-server-certificates.sh"
  },
  "keywords": ["nginx", "static-files", "spa", "frontend", "docker"],
  "author": "LuckyLove Team",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
